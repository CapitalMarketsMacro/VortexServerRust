{
  "server": {
    "bind": "0.0.0.0:4000",
    "ws_path": "/ws"
  },
  "logging": {
    "level": "info,async_nats=warn",
    "format": "pretty",
    "dir": "logs",
    "file_prefix": "vortex-server"
  },
  "transports": {
    "nats": {
      "url": "nats://localhost:4222",
      "name": "vortex-server",
      "credentials_file": null
    },
    "solace": {
      "host": "tcps://broker.example.com:55443",
      "vpn": "default",
      "username": "vortex",
      "password": "REPLACE_ME",
      "client_name": "vortex-server"
    }
  },
  "tables": [
    {
      "name": "RatesMarketData",
      "composite_index": ["MarketId", "Id"],
      "stringify_columns": ["Bid", "Ask"],
      "source": {
        "transport": "nats_core",
        "subject": "rates.marketData",
        "format": "json_row"
      }
    },
    {
      "name": "Orders",
      "index": "OrderId",
      "source": {
        "transport": "nats_jetstream",
        "stream": "ORDERS",
        "subject": "orders.>",
        "consumer": "vortex-orders",
        "format": "json_row"
      }
    },
    {
      "name": "Executions",
      "index": "ExecId",
      "source": {
        "transport": "solace",
        "topic": "executions/>",
        "format": "json_row"
      }
    },
    {
      "name": "MarketTicks",
      "index": "tickId",
      "source": {
        "transport": "websocket",
        "endpoint": "wss://feed.example.com/ticks",
        "subprotocols": [],
        "format": "json_row"
      }
    }
  ]
}
